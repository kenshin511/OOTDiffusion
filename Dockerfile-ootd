# Dockerfile (OOTDiffusion)
FROM pytorch/pytorch:2.0.1-cuda11.7-cudnn8-devel

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /workspace

# ---- OS deps (opencv, pillow, etc.) ----
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl wget ca-certificates \
    libgl1 libglib2.0-0 libsm6 libxext6 libxrender1 \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

# ---- Python deps ----
# PyTorch 2.0.1에 맞는 torchvision, torchaudio 버전을 한 번에 설치합니다.
RUN pip install --upgrade pip setuptools wheel && \
    pip install --no-cache-dir \
    torchvision==0.15.2 \
    torchaudio==2.0.2 \
    numpy==1.24.4 \
    scipy==1.10.1 \
    scikit-image==0.21.0 \
    opencv-python==4.7.0.72 \
    pillow==9.4.0 \
    diffusers==0.24.0 \
    transformers==4.36.2 \
    accelerate==0.26.1 \
    matplotlib==3.7.4 \
    tqdm==4.64.1 \
    gradio==4.16.0 \
    config==0.5.1 \
    einops==0.7.0 \
    onnxruntime==1.16.2 \
    filelock==3.13.1 \
    huggingface_hub==0.23.4

# ---- Project files ----
# COPY . /workspace

EXPOSE 7860

CMD ["/bin/bash"]